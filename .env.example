# ===========================================
# FB News Automation - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# ===========================================

# ===========================================
# API Keys (Required)
# ===========================================

# NewsAPI Key - Get free key from https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# OpenRouter API Key - Get free key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ===========================================
# Facebook Configuration (Required for posting)
# ===========================================

# Facebook Page Access Token
# Get from: Facebook Developer Dashboard > Your App > Tools > Graph API Explorer
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Facebook Page ID
# Find your Page ID: https://findmyfbid.in/
FB_PAGE_ID=your_facebook_page_id_here

# ===========================================
# Optional Configuration
# ===========================================

# Maximum trends to process per cycle (default: 3)
MAX_TRENDS=3

# Hours to check for duplicate topics (default: 48)
DUPLICATE_HOURS=48

# Skip Facebook posting (set to true for testing)
SKIP_FACEBOOK=false

# OpenRouter model to use (default: mistralai/mistral-7b-instruct:free)
# Other free options: google/gemma-7b-it:free, meta-llama/llama-2-7b-chat:free
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ===========================================
# Storage & Output Directories
# ===========================================

# Directory for SQLite database and JSON storage
STORAGE_DIR=./storage

# Directory for generated news card images
OUTPUT_DIR=./output

# Directory for log files
LOG_DIR=./logs

# Path to configuration file
CONFIG_PATH=./config/config.json

# ===========================================
# Railway Deployment Variables
# ===========================================

# Railway will automatically set these
# DATABASE_URL is set by Railway for PostgreSQL
# PORT is set by Railway for web services

# ===========================================
# n8n Webhook Configuration (Optional)
# ===========================================

# Webhook URL for notifications
WEBHOOK_URL=

# ===========================================
# Logging Configuration
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable detailed logging
VERBOSE_LOGGING=false