        "sort_by": "relevancy",
        "hours_back": 24
    },
    "headline": {
        "max_words": 14,
        "model": "mistralai/mistral-7b-instruct:free",
        "temperature": 0.7,
        "max_tokens": 60
    },
    "image": {
        "canvas_width": 1080,
        "canvas_height": 1080,
        "quality": 95,
        "contrast_enhancement": 1.1,
        "gradient_start_percent": 0.45,
        "breaking_label_color": [
            220,
            20,
            20
        ],
        "headline_font_size": 52,
        "watermark_text": "FB News"
    },
    "facebook": {
        "api_version": "v18.0",
        "post_timeout": 60
    },
    "storage": {
        "use_json": false,
        "cleanup_days": 30,
        "max_history_entries": 100
    },
    "logging": {
        "level": "INFO",
        "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
        "max_log_files": 7
    }
